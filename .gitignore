# python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# environments
.venv/
venv/

# results artifacts (regenerable); keep the dir + committed reference CSVs only
results/*.png
results/*.pdf

# sealed certified study blocks (multi-GB, immutable, receipt-verified in
# place; their manifests and amendment chains ARE committed)
results/graphlog-certified/g6/
results/graphlog-certified/g7/
results/graphlog-certified/.g*.partial/

# reading-app session data + trained creatures (local state, regenerable)
data/

# fetched public-domain corpus (re-derivable from corpus/MANIFEST.json via
# scripts/fetch_corpus.py — the manifest + loader are committed, the bytes aren't)
corpus/raw/

# os / editor
.DS_Store
*.swp
data/graphlog/
